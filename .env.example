# ── Proveedor por defecto al arrancar: nvidia | chatgpt | gemini ─────
DEFAULT_PROVIDER=gemini

# ── Nvidia NIM / OpenAI-compatible ──────────────────────────────────
OPENAI_COMPAT_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_COMPAT_API_KEY=replace_me
OPENAI_COMPAT_MODEL=qwen/qwen3-coder-480b-a35b-instruct
OPENAI_COMPAT_TEMPERATURE=0.7
OPENAI_COMPAT_TOP_P=0.8
OPENAI_COMPAT_MAX_TOKENS=4096

# ── ChatGPT (OpenAI nativo) ────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ── Google Gemini ──────────────────────────────────────────────────
# Modelos recomendados (free tier): gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.8
GEMINI_MAX_TOKENS=4096

# ── Autorización ───────────────────────────────────────────────────
# Un solo número:
ALLOWED_SENDER=644619636
# Múltiples números (coma separados) — supera a ALLOWED_SENDER si se define:
# ALLOWED_SENDERS=644619636,612345678,699999999
ALLOWED_SENDER_JID=
# Múltiples JIDs (coma separados):
# ALLOWED_SENDER_JIDS=143658166780063@lid,987654321@s.whatsapp.net

# ── Almacenamiento ─────────────────────────────────────────────────
SESSION_STORE_PATH=./data/sessions.json
OUTPUT_DIR=./data/outputs
AUTH_DIR=./auth_info_multi

# ── Límites ────────────────────────────────────────────────────────
MAX_CONTEXT_MESSAGES=20
MAX_FILE_SIZE_BYTES=524288
MAX_REVIEW_FILES=15
MAX_REVIEW_CHARS_PER_FILE=4000

# ── Seguridad ──────────────────────────────────────────────────────
ALLOWED_REVIEW_BASE_PATH=

# ── Reconexión ─────────────────────────────────────────────────────
MAX_RECONNECT_ATTEMPTS=10

# ── LLM ────────────────────────────────────────────────────────────
LLM_TIMEOUT_MS=120000
RATE_LIMIT_PER_MINUTE=0

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CRM Hipotecas ──────────────────────────────────────────────────
CRM_API_URL=https://api.tucrm.com/v1
CRM_BEARER_TOKEN=your_token_here
